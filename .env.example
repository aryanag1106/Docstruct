# DocStruct environment variables
# Copy this file to .env and fill in your values (never commit .env itself)

# Path to a downloaded GGUF model file for the 'llm' backend
# Download with: python scripts/download_model.py
DOCSTRUCT_MODEL_PATH=models/qwen2.5-0.5b-instruct-q4_k_m.gguf

# Ollama server URL (default: http://localhost:11434)
DOCSTRUCT_OLLAMA_URL=http://localhost:11434

# Ollama model tag to use (must already be pulled: ollama pull <tag>)
DOCSTRUCT_OLLAMA_MODEL=qwen2.5:0.5b

# Tesseract executable path (Windows only — set if tesseract isn't on PATH)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
